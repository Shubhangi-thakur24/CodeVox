{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES6",
    "lib": ["ES2020"],
    "types": ["node"], 
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "moduleResolution":"node",
    
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".vscode-test"]
}